{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CI Review Findings",
  "description": "Schema for structured code review findings output",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["file", "line", "severity", "issue", "fix"],
    "additionalProperties": false,
    "properties": {
      "file": {
        "type": "string",
        "description": "Relative path to the file containing the finding"
      },
      "line": {
        "type": "string",
        "description": "Line number or range (e.g. \"23\" or \"23-27\")"
      },
      "severity": {
        "type": "string",
        "enum": ["Critical", "Major", "Minor"],
        "description": "Severity level of the finding"
      },
      "issue": {
        "type": "string",
        "description": "One-sentence description of the actual problem"
      },
      "fix": {
        "type": "string",
        "description": "Concrete suggested fix for the issue"
      }
    }
  }
}
